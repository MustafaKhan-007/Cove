# COVE Website Rebuild — .env.example — environment variable template
# Copy to .env for local development. Never commit real secrets.

FLASK_ENV=development
SECRET_KEY=dev-secret-change-me

# Production database (Render injects this automatically via render.yaml)
# DATABASE_URL=postgresql://user:pass@host:5432/cove

# Optional: SMTP for booking confirmation emails (Flask-Mail)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=termin@cove.de
